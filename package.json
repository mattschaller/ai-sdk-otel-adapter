{
  "name": "ai-sdk-otel-adapter",
  "version": "0.1.3",
  "description": "Vendor-neutral OTel SpanProcessor that remaps Vercel AI SDK ai.* attributes to gen_ai.* semantic conventions",
  "keywords": [
    "opentelemetry",
    "vercel-ai-sdk",
    "gen-ai",
    "semantic-conventions",
    "span-processor",
    "observability",
    "grafana",
    "datadog",
    "jaeger"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mattschaller/ai-sdk-otel-adapter.git"
  },
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "prepublishOnly": "npm run build && npm run test"
  },
  "peerDependencies": {
    "@opentelemetry/api": ">=1.0.0",
    "@opentelemetry/sdk-trace-base": ">=1.0.0"
  },
  "devDependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-trace-base": "^1.30.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  }
}
